 PREEMPT_RT_PRESENT=0
 
 NVIDIA_OOT_PATH="/usr/src/nvidia/nvidia-public"
-MODULE_SYMVERS_PATHS="$OUTPUT/Module.symvers"
+MODULE_SYMVERS_PATHS=""
+
+# Collect all available symbol version files.
+# Kernel 7.0+ generates vmlinux.symvers instead of (or alongside)
+# Module.symvers for built-in symbol exports.
+for _symvers in "$OUTPUT/Module.symvers" "$OUTPUT/vmlinux.symvers"; do
+    [ -f "$_symvers" ] && MODULE_SYMVERS_PATHS="$MODULE_SYMVERS_PATHS $_symvers"
+done
 
